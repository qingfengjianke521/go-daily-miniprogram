/* Top bar */
.top-bar { background: #fff; position: fixed; top: 0; left: 0; right: 0; z-index: 100; }
.top-bar-inner { height: 44px; display: flex; align-items: center; padding: 0 24rpx; gap: 20rpx; }
.close-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.close-icon { font-size: 36rpx; color: #AFAFAF; font-weight: 300; }
.top-progress-track { flex: 1; height: 28rpx; background: #E5E5E5; border-radius: 14rpx; overflow: hidden; }
.top-progress-fill { height: 100%; border-radius: 14rpx; background: #58CC02; transition: width 0.4s ease; }
.top-counter { font-size: 28rpx; font-weight: 700; color: #AFAFAF; min-width: 80rpx; text-align: right; }

/* Content */
.lesson-content {
  min-height: 100vh;
  padding: 24rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Lesson header */
.lesson-header {
  text-align: center;
  padding: 16rpx 0;
}
.lesson-num {
  font-size: 26rpx;
  color: #1C94E0;
  font-weight: 600;
  display: block;
}
.lesson-title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C94E0;
  display: block;
}

/* Text area */
.text-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}
.instruction-text {
  font-size: 30rpx;
  color: #4B4B4B;
  line-height: 1.6;
}

/* Board */
.board-wrap {
  width: 100%;
}

/* Quiz */
.quiz-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.quiz-option {
  background: #fff;
  border: 4rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: #4B4B4B;
  font-weight: 500;
}
.quiz-option.correct {
  background: #E8F5E9;
  border-color: #58CC02;
  color: #2E7D32;
}
.quiz-option.wrong {
  background: #FFEBEE;
  border-color: #FF4B4B;
  color: #C62828;
}

/* Feedback */
.feedback-bar {
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
}
.feedback-correct { background: #E8F5E9; }
.feedback-wrong { background: #FFEBEE; }
.feedback-msg { font-size: 28rpx; font-weight: 600; }
.feedback-correct .feedback-msg { color: #58CC02; }
.feedback-wrong .feedback-msg { color: #FF4B4B; }

/* Bottom */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}
.btn-next {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-green { background: #58CC02; }
.btn-blue { background: #1C94E0; }
