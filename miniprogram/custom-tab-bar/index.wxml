<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-btn {{selected === index ? 'tab-btn-on' : ''}}"
    bindtap="switchTab"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
  >
    <text class="tab-emoji">{{item.icon}}</text>
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
