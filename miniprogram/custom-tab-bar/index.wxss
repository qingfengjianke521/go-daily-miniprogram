.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  z-index: 999;
}

.tab-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tab-emoji { font-size: 36rpx; }
.tab-label { font-size: 20rpx; color: #999; font-weight: 600; }
.tab-btn-on .tab-label { color: #58CC02; font-weight: 700; }
