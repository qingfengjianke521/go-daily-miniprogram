/* ===== Q版棋子精灵 ===== */
.mascot {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
}

/* 尺寸变量 */
.mascot-sm { --sz: 72rpx; }
.mascot-md { --sz: 110rpx; }
.mascot-lg { --sz: 160rpx; }

/* ===== 身体 ===== */
.body {
  width: var(--sz); height: var(--sz);
  border-radius: 50%;
  position: relative;
  box-shadow:
    0 calc(var(--sz) * 0.08) 0 rgba(0,0,0,0.15),
    inset 0 calc(var(--sz) * -0.08) calc(var(--sz) * 0.15) rgba(0,0,0,0.1);
}
.mascot-black .body {
  background: radial-gradient(circle at 38% 32%, #666 0%, #222 50%, #000 100%);
}
.mascot-white .body {
  background: radial-gradient(circle at 38% 32%, #fff 0%, #f0f0f0 50%, #ddd 100%);
  border: 2rpx solid #e0e0e0;
}

/* 高光 */
.body-shine {
  position: absolute; top: 10%; left: 18%;
  width: 35%; height: 22%;
  background: radial-gradient(ellipse, rgba(255,255,255,0.5) 0%, transparent 70%);
  border-radius: 50%;
  transform: rotate(-15deg);
}
.mascot-white .body-shine {
  background: radial-gradient(ellipse, rgba(255,255,255,0.9) 0%, transparent 70%);
}

/* ===== 呆毛（带爱心） ===== */
.ahoge {
  position: absolute;
  top: calc(var(--sz) * -0.22);
  left: 50%;
  transform: translateX(-30%);
  z-index: 5;
}
.ahoge-stem {
  width: calc(var(--sz) * 0.04);
  height: calc(var(--sz) * 0.18);
  border-radius: calc(var(--sz) * 0.02);
  transform: rotate(15deg);
  transform-origin: bottom;
}
.mascot-black .ahoge-stem { background: #333; }
.mascot-white .ahoge-stem { background: #bbb; }

.ahoge-heart {
  position: absolute;
  top: calc(var(--sz) * -0.06);
  left: calc(var(--sz) * -0.02);
  font-size: calc(var(--sz) * 0.16);
  color: #FF6B8A;
  animation: ahoge-bob 2s ease-in-out infinite;
}
@keyframes ahoge-bob {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-4rpx) rotate(5deg); }
}

/* ===== 眼睛（大圆眼，占脸1/3） ===== */
.eyes {
  position: absolute;
  top: 28%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: calc(var(--sz) * 0.08);
  z-index: 3;
}
.eye {
  width: calc(var(--sz) * 0.26);
  height: calc(var(--sz) * 0.3);
  border-radius: 50%;
  position: relative;
  overflow: hidden;
}
.eye-white {
  width: 100%; height: 100%;
  border-radius: 50%;
  position: absolute;
}
.mascot-black .eye-white { background: white; }
.mascot-white .eye-white { background: white; border: 2rpx solid #ddd; }

.pupil {
  width: 65%; height: 65%;
  border-radius: 50%;
  position: absolute;
  bottom: 12%; left: 50%;
  transform: translateX(-50%);
}
.mascot-black .pupil { background: #111; }
.mascot-white .pupil { background: #333; }

/* 双层高光 */
.pupil-highlight {
  position: absolute; border-radius: 50%;
  background: white;
}
.pupil-highlight.h1 {
  width: 35%; height: 35%;
  top: 15%; right: 15%;
}
.pupil-highlight.h2 {
  width: 18%; height: 18%;
  bottom: 25%; left: 20%;
  opacity: 0.7;
}

/* 眨眼 */
.blink .eye {
  animation: cute-blink 4s ease-in-out infinite;
}
@keyframes cute-blink {
  0%, 92%, 100% { transform: scaleY(1); }
  95% { transform: scaleY(0.05); }
}

/* 开心眯眼 */
.squint .eye {
  transform: scaleY(0.3);
  border-radius: 50%;
}
.squint .eye-white {
  background: transparent;
}
.squint .pupil, .squint .pupil-highlight { display: none; }
.squint.mascot-black .eye::after {
  content: ''; position: absolute; top: 30%; left: 10%; right: 10%;
  height: 40%; border-bottom: calc(var(--sz) * 0.04) solid white;
  border-radius: 0 0 50% 50%;
}
.squint.mascot-white .eye::after {
  content: ''; position: absolute; top: 30%; left: 10%; right: 10%;
  height: 40%; border-bottom: calc(var(--sz) * 0.04) solid #333;
  border-radius: 0 0 50% 50%;
}

/* ===== 腮红 ===== */
.cheeks {
  position: absolute;
  top: 52%;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  display: flex;
  justify-content: space-between;
  z-index: 2;
}
.cheek {
  width: calc(var(--sz) * 0.14);
  height: calc(var(--sz) * 0.1);
  border-radius: 50%;
  background: rgba(255, 140, 160, 0.35);
}

/* ===== 嘴巴 ===== */
.mouth {
  position: absolute;
  bottom: 22%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}
.mouth-smile {
  width: calc(var(--sz) * 0.14);
  height: calc(var(--sz) * 0.06);
  border-bottom: calc(var(--sz) * 0.03) solid;
  border-radius: 0 0 50% 50%;
}
.mascot-black .mouth-smile { border-color: rgba(255,255,255,0.7); }
.mascot-white .mouth-smile { border-color: rgba(0,0,0,0.4); }

.mouth-happy {
  width: calc(var(--sz) * 0.2);
  height: calc(var(--sz) * 0.12);
  background: #FF6B8A;
  border-radius: 0 0 calc(var(--sz) * 0.12) calc(var(--sz) * 0.12);
}
.mouth-o {
  width: calc(var(--sz) * 0.1);
  height: calc(var(--sz) * 0.1);
  background: #FF6B8A;
  border-radius: 50%;
}

/* ===== 小脚 ===== */
.feet {
  display: flex;
  gap: calc(var(--sz) * 0.2);
  margin-top: calc(var(--sz) * -0.04);
  z-index: 1;
}
.foot {
  width: calc(var(--sz) * 0.22);
  height: calc(var(--sz) * 0.1);
  border-radius: 50%;
}
.mascot-black .foot {
  background: radial-gradient(ellipse at top, #333, #111);
}
.mascot-white .foot {
  background: radial-gradient(ellipse at top, #eee, #ccc);
  border: 1rpx solid #ddd;
}

/* ===== 对话气泡 ===== */
.bubble {
  position: absolute;
  top: calc(var(--sz) * -0.5);
  left: calc(var(--sz) * 0.6);
  background: white;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  font-size: calc(var(--sz) * 0.14);
  color: #4B4B4B;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  z-index: 10;
  animation: bubble-pop 0.3s ease-out;
}
.bubble-tail {
  position: absolute;
  bottom: -8rpx; left: 16rpx;
  width: 0; height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid white;
}
@keyframes bubble-pop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* ===== 动画 ===== */
.anim-bounce {
  animation: m-bounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 2;
}
@keyframes m-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.anim-jump {
  animation: m-jump 0.8s ease infinite;
}
@keyframes m-jump {
  0%, 100% { transform: translateY(0) scale(1); }
  30% { transform: translateY(-28rpx) scale(1.05); }
  50% { transform: translateY(-28rpx) scale(1.05); }
  80% { transform: translateY(4rpx) scale(0.95); }
}

.anim-nod {
  animation: m-nod 0.8s ease 2;
}
@keyframes m-nod {
  0%, 100% { transform: rotate(0); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(6deg); }
}

.anim-wave {
  animation: m-wave 1.5s ease infinite;
}
@keyframes m-wave {
  0%, 100% { transform: rotate(0); }
  25% { transform: rotate(-3deg) translateY(-4rpx); }
  75% { transform: rotate(3deg) translateY(-4rpx); }
}
