.admin-page { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.title { font-size: 40rpx; font-weight: 700; text-align: center; padding: 30rpx 0; }
.warn { text-align: center; color: #e74c3c; font-size: 28rpx; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 20rpx 0; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.btn-row { display: flex; gap: 16rpx; }
.result { margin-top: 16rpx; font-size: 26rpx; color: #333; }
.result text { display: block; line-height: 1.8; }
.progress { margin-top: 16rpx; font-size: 26rpx; color: #1890ff; }
.issue-list { margin-top: 16rpx; max-height: 500rpx; overflow-y: auto; }
.issue-item { font-size: 22rpx; color: #e74c3c; line-height: 1.6; border-bottom: 1rpx solid #f0f0f0; padding: 6rpx 0; }
.log-box { max-height: 400rpx; background: #1a1a2e; border-radius: 12rpx; padding: 16rpx; }
.log-line { font-size: 22rpx; color: #0f0; font-family: monospace; line-height: 1.6; }
.running-indicator { text-align: center; padding: 20rpx; color: #1890ff; font-size: 28rpx; }
