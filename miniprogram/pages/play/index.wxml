<view style="display:flex;flex-direction:column;height:100vh;">
<!-- 顶部栏：✕ + 等级 + 分数 + 进度条(x/3) -->
<view class="top-bar" style="flex-shrink:0;padding-top:{{statusBarHeight}}px;">
  <view class="top-bar-inner">
    <view class="close-btn" bindtap="handleBack">
      <text class="close-icon">✕</text>
    </view>
    <block wx:if="{{isVillageMode}}">
      <text class="top-level">{{villageNodeName}}</text>
      <view class="top-progress-track">
        <view class="top-progress-fill {{villageProgress >= 100 ? 'progress-full' : ''}}" style="width:{{villageProgress}}%;"></view>
      </view>
      <text class="top-counter">{{problemIndex}}/{{totalProblems}}</text>
    </block>
    <block wx:else>
      <text class="top-level">{{userLevel}}</text>
      <text class="top-rating">{{userRating}}分</text>
      <view class="top-progress-track">
        <view class="top-progress-fill {{dailyProgress >= 100 ? 'progress-full' : ''}}" style="width:{{dailyProgress}}%;"></view>
      </view>
      <text class="top-counter">{{dailyDone}}/3</text>
    </block>
  </view>
</view>

<view class="play-content">
  <!-- Description -->
  <view class="desc-row {{categoryBorderClass}}">
    <text class="desc-text">{{description}}</text>
    <text wx:if="{{goalHint}}" class="goal-hint">· {{goalHint}}</text>
    <text class="category-tag {{categoryClass}}">{{category}}</text>
  </view>
  <!-- Status line -->
  <view class="status-line">
    <text wx:if="{{showHint}}" class="status-text" style="color:#888;">{{hintMsg}}</text>
    <text wx:elif="{{showingSolution}}" class="status-text" style="color:#58CC02;">正解演示中...</text>
    <text wx:elif="{{interactive && !advancing}}" class="status-text text-999">点击棋盘上正确的位置</text>
    <text wx:elif="{{advancing}}" class="status-text text-999">对方应手中...</text>
    <text wx:else class="status-text text-999"> </text>
  </view>

  <!-- Board -->
  <view class="board-wrap {{boardAnimClass}}">
    <go-board
      boardSize="{{boardSize}}"
      stones="{{stones}}"
      viewRegion="{{viewRegion}}"
      interactive="{{interactive}}"
      currentColor="{{currentColor}}"
      lastMove="{{lastMove}}"
      moveHistory="{{moveHistory}}"
      highlightPoints="{{highlightPoints}}"
      bindmove="onBoardMove"
    />
    <!-- Game Juice 反馈层 -->
    <view wx:if="{{showCorrectAnim}}" class="feedback-overlay">
      <view class="correct-check animate">✓</view>
      <view wx:if="{{ratingChange}}" class="score-fly animate">+{{ratingChange}}</view>
    </view>
  </view>

  <!-- 全屏金色闪光（连击5/10） -->
  <view wx:if="{{showGoldFlash}}" class="gold-flash-overlay"></view>

  <!-- 连击大字爆出 -->
  <view wx:if="{{showComboBurst}}" class="combo-burst">{{comboBurstText}}</view>

  <!-- Controls -->
  <view class="controls-row">
    <button class="nav-btn" bindtap="handlePrevProblem" disabled="{{problemIndex <= 1}}">上一题</button>
    <text wx:if="{{hasAttempted && !isDone && !answerRevealed}}" class="reveal-btn" bindtap="handleRevealAnswer">💡</text>
    <button wx:elif="{{isDone || answerRevealed}}" class="nav-btn" bindtap="handleRetry">重做</button>
    <view wx:else class="hint-text">{{problemIndex}}/{{totalProblems}}</view>
    <button class="nav-btn nav-btn-primary" bindtap="handleNextProblem">下一题</button>
  </view>
</view>
</view>

<!-- ========== 段位升级浮层 ========== -->
<view wx:if="{{showLevelUp}}" class="levelup-overlay">
  <view class="levelup-content animate-pop">
    <text class="levelup-emoji">🎊</text>
    <text class="levelup-title">恭喜升级！</text>
    <text class="levelup-name">{{levelUpName}}</text>
  </view>
</view>

<!-- ========== 底部反馈面板 ========== -->
<!-- overlay 已移除，不阻挡棋盘点击 -->
<view class="feedback-panel {{feedbackVisible ? 'show' : ''}} feedback-{{feedbackType}}">
  <!-- 顶部行：吉祥物 + 文案 + 分数 -->
  <view class="flex items-center" style="margin-bottom:32rpx;">
    <mascot
      wx:if="{{feedbackType === 'correct'}}"
      color="black" mood="happy" size="sm"
    />
    <mascot
      wx:elif="{{feedbackType === 'wrong'}}"
      color="white" mood="encourage" size="sm"
    />
    <view wx:else class="feedback-icon feedback-icon-hint">
      <text>📖</text>
    </view>
    <text class="feedback-title">{{feedbackText}}</text>
    <text wx:if="{{feedbackScore}}" class="feedback-score">
      {{feedbackScore > 0 ? '+' : ''}}{{feedbackScore}}
    </text>
  </view>

  <!-- 继续按钮 -->
  <button
    class="btn {{feedbackType === 'wrong' ? 'btn-orange' : 'btn-primary'}} btn-lg w-full rounded-xl"
    wx:if="{{feedbackCanContinue}}"
    bindtap="handleFeedbackContinue"
  >{{feedbackButtonText}}</button>
</view>
