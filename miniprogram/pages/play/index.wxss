/* ========== Duolingo-style Top Bar ========== */
.top-bar {
  background: #FFFFFF;
  position: relative;
  z-index: 10;
}
.top-bar-inner {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 20rpx;
}
.close-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.close-icon {
  font-size: 36rpx;
  color: #AFAFAF;
  font-weight: 300;
}
.top-progress-track {
  flex: 1;
  height: 28rpx;
  background: #E5E5E5;
  border-radius: 14rpx;
  overflow: hidden;
}
.top-progress-fill {
  height: 100%;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #58CC02, #7EE832);
  transition: width 0.4s ease;
}
.top-level {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF9500;
  background: #FFF3E0;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}
.top-rating {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}
.top-counter {
  font-size: 26rpx;
  font-weight: 700;
  color: #AFAFAF;
  min-width: 50rpx;
  text-align: right;
  white-space: nowrap;
}

/* ========== Content ========== */
.play-content {
  display: flex;
  flex-direction: column;
  padding: 16rpx 0 0;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

/* Description */
.desc-row {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  margin: 0 32rpx;
  border-left: 6rpx solid #1C94E0;
  flex-shrink: 0;
}
.desc-row.border-tesuji { border-left-color: #9B59B6; }
.desc-row.border-beginner { border-left-color: #58CC02; }
.desc-row.border-endgame { border-left-color: #FF9500; }
.desc-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #4B4B4B;
}
.goal-hint {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #888;
  font-weight: 400;
}
.category-tag {
  margin-left: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  vertical-align: middle;
}
/* 分类颜色 */
.category-tag { background: #F0FBE5; color: #58CC02; }
.tag-life { background: #E8F4FD; color: #1C94E0; }
.tag-tesuji { background: #F3E8FD; color: #9B59B6; }
.tag-endgame { background: #FFF3E0; color: #FF9500; }
.tag-beginner { background: #F0FBE5; color: #58CC02; }
.tag-joseki { background: #E0F7FA; color: #00ACC1; }
.tag-middle { background: #FFF8E1; color: #FFB300; }

/* Status line */
.status-line {
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  flex-shrink: 0;
}
.status-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* Board */
.board-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  overflow: hidden;
  box-shadow: none;
  border-radius: 0;
  position: relative;
}

/* Controls */
.controls-row {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}
.controls-row .btn {
  flex: 1;
}

/* 段位升级浮层 */
.levelup-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 300;
}
.levelup-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  background: white;
  padding: 64rpx 80rpx;
  border-radius: 32rpx;
}
.levelup-emoji { font-size: 120rpx; }
.levelup-title { font-size: 36rpx; font-weight: 700; color: #FFB300; }
.levelup-name { font-size: 56rpx; font-weight: 700; color: #4B4B4B; }
.debug-row { text-align: center; padding: 4rpx 0; }
.debug-text { font-size: 20rpx; color: #AFAFAF; }
.hint-text { text-align: center; font-size: 26rpx; color: #999; padding: 16rpx 0; }

/* 上一题/下一题 */
.nav-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  font-size: 28rpx; font-weight: 600; border-radius: 16rpx;
  background: #fff; color: #666; border: 2rpx solid #E5E5E5; padding: 0;
  box-shadow: 0 2rpx 0 #E0E0E0;
}
.nav-btn.disabled { opacity: 0.35; }
.nav-btn-primary { background: #58CC02; color: #fff; border-color: #46A302; box-shadow: 0 4rpx 0 #46A302; }
.controls-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom)); flex-shrink: 0; }
.retry-btn { font-size: 36rpx; padding: 8rpx 16rpx; color: #999; }

/* 查看答案 */
.reveal-row { text-align: center; padding: 4rpx 0; flex-shrink: 0; }
.reveal-btn { font-size: 26rpx; color: #999; }

/* 橙色按钮 */
.btn-orange { background: #FF9500 !important; color: #fff !important; border: none !important; }

/* ========== Game Juice 动画 ========== */

/* 答对：大✓弹出 */
@keyframes pop-in {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.5); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* 分数向上飞 */
@keyframes float-up {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-200rpx); opacity: 0; }
}

/* 棋盘摇晃 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-6rpx); }
  40% { transform: translateX(6rpx); }
  60% { transform: translateX(-4rpx); }
  80% { transform: translateX(4rpx); }
}

/* 棋盘微弹 */
@keyframes board-bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

/* 金色闪光 */
@keyframes flash-gold {
  0% { opacity: 0; }
  30% { opacity: 0.5; }
  100% { opacity: 0; }
}

/* 红色闪烁 */
@keyframes blink-red {
  0%, 50%, 100% { opacity: 0; }
  25%, 75% { opacity: 0.7; }
}

/* 左滑出 */
@keyframes slide-out-left {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-100%); opacity: 0; }
}

/* 右滑入 */
@keyframes slide-in-right {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* 反馈层 */
.feedback-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
  z-index: 50;
}

.correct-check {
  font-size: 180rpx;
  font-weight: 900;
  color: #4CAF50;
  text-shadow: 0 4rpx 20rpx rgba(76,175,80,0.5);
}
.correct-check.animate {
  animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

.score-fly {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 72rpx;
  font-weight: 900;
  color: #58CC02;
  text-shadow: 0 4rpx 16rpx rgba(88,204,2,0.4);
}
.score-fly.animate {
  animation: float-up 0.8s ease-out forwards;
}

/* 棋盘动画状态 */
.board-shake { animation: shake 0.3s ease-in-out; }
.board-bounce { animation: board-bounce 0.2s ease-out; }
.board-slide-out { animation: slide-out-left 0.25s forwards; }
.board-slide-in { animation: slide-in-right 0.25s forwards; }

/* 全屏金色闪光 */
.gold-flash-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(circle, rgba(255,215,0,0.6), rgba(255,165,0,0.3));
  pointer-events: none;
  z-index: 999;
  animation: flash-gold 0.3s ease-out forwards;
}

/* 连击弹出大字 */
.combo-burst {
  position: fixed;
  top: 40%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 96rpx;
  font-weight: 900;
  color: #FFB300;
  text-shadow:
    0 0 20rpx rgba(255,179,0,0.8),
    0 4rpx 12rpx rgba(0,0,0,0.3);
  pointer-events: none;
  z-index: 1000;
  animation: pop-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 连击文案加成 */
.feedback-combo-2 .feedback-title {
  color: #FF9600;
  text-shadow: 0 0 8rpx rgba(255,150,0,0.4);
  animation: board-bounce 0.6s ease-in-out infinite;
}
.feedback-combo-3 {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3) !important;
}
.feedback-combo-3 .feedback-title {
  font-size: 44rpx;
  color: #FF8F00;
}

/* 进度条弹性 */
.top-progress-fill {
  transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.top-progress-fill.progress-full {
  animation: board-bounce 0.5s ease-out;
}
