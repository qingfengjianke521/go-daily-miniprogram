/* ========== Duolingo-style Top Bar ========== */
.top-bar {
  background: #FFFFFF;
  position: relative;
  z-index: 10;
}
.top-bar-inner {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 20rpx;
}
.close-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.close-icon {
  font-size: 36rpx;
  color: #AFAFAF;
  font-weight: 300;
}
.top-progress-track {
  flex: 1;
  height: 28rpx;
  background: #E5E5E5;
  border-radius: 14rpx;
  overflow: hidden;
}
.top-progress-fill {
  height: 100%;
  border-radius: 14rpx;
  background: #58CC02;
  transition: width 0.4s ease;
}
.top-counter {
  font-size: 28rpx;
  font-weight: 700;
  color: #AFAFAF;
  min-width: 60rpx;
  text-align: right;
}

/* ========== Content ========== */
.play-content {
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx 48rpx;
  gap: 20rpx;
  min-height: 0;
}

/* Description */
.desc-row {
  text-align: center;
}
.desc-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #4B4B4B;
}
.goal-hint {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #888;
  font-weight: 400;
}
.category-tag {
  margin-left: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 9999rpx;
  vertical-align: middle;
}
/* 分类颜色 */
.category-tag { background: #F0FBE5; color: #58CC02; }
.tag-life { background: #E8F4FD; color: #1C94E0; }
.tag-tesuji { background: #F3E8FD; color: #9B59B6; }
.tag-endgame { background: #FFF3E0; color: #FF9500; }
.tag-beginner { background: #F0FBE5; color: #58CC02; }
.tag-joseki { background: #E0F7FA; color: #00ACC1; }
.tag-middle { background: #FFF8E1; color: #FFB300; }

/* Status line */
.status-line {
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.status-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* Board */
.board-wrap {
  width: 100%;
}

/* Controls */
.controls-row {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}
.controls-row .btn {
  flex: 1;
}

/* 段位升级浮层 */
.levelup-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 300;
}
.levelup-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  background: white;
  padding: 64rpx 80rpx;
  border-radius: 32rpx;
}
.levelup-emoji { font-size: 120rpx; }
.levelup-title { font-size: 36rpx; font-weight: 700; color: #FFB300; }
.levelup-name { font-size: 56rpx; font-weight: 700; color: #4B4B4B; }
.debug-row { text-align: center; padding: 4rpx 0; }
.debug-text { font-size: 20rpx; color: #AFAFAF; }
.hint-text { text-align: center; font-size: 26rpx; color: #999; padding: 16rpx 0; }
