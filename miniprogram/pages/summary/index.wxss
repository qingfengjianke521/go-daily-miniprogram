.summary-page {
  min-height: 100vh;
  background: #F7F7F7;
}

.summary-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx;
  gap: 36rpx;
}

.hidden { opacity: 0; transform: scale(0.8); }

/* 纸屑 */
.confetti-container {
  position: fixed; top: 0; left: 0; right: 0; height: 100vh;
  pointer-events: none; z-index: 100; overflow: hidden;
}
.confetti-piece {
  position: absolute; top: -20rpx;
  width: 16rpx; height: 24rpx;
  border-radius: 4rpx;
  animation: confetti-fall 2.5s ease-out forwards;
}
@keyframes confetti-fall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* 吉祥物庆祝 */
.mascot-celebrate {
  display: flex; gap: 32rpx; margin-bottom: 16rpx;
}
.animate-pop {
  animation: pop-in 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}
@keyframes pop-in {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* Emoji - now smaller since mascots are the focus */
.emoji { font-size: 64rpx; }

/* Title */
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #4B4B4B;
}
.subtitle {
  font-size: 26rpx;
  color: #AFAFAF;
  text-align: center;
}

/* Circles row */
.circles-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}
.path-line-sm {
  width: 40rpx; height: 6rpx;
  background: #E5E5E5;
  margin-top: 42rpx;
  border-radius: 3rpx;
}
.line-done { background: #58CC02; }

.circle-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.circle {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #E5E5E5;
}
.correct-circle { background: #58CC02; border-color: #58CC02; }
.wrong-circle { background: #FF4B4B; border-color: #FF4B4B; }
.pending-circle { background: transparent; }

.circle-score {
  font-size: 24rpx;
  font-weight: 700;
}

/* Rating card */
.rating-card {
  width: 100%;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.rating-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.rating-change {
  font-size: 56rpx;
  font-weight: 700;
}
.level-row {
  display: flex;
  justify-content: space-between;
}
.level-bar-track {
  width: 100%;
  height: 24rpx;
  background: #F0F0F0;
  border-radius: 12rpx;
  overflow: hidden;
}
.level-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #58CC02, #7AE030);
  transition: width 1s ease;
}

/* Streak */
.streak-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  background: #FFF6E5;
}
.streak-fire { font-size: 40rpx; }
.streak-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF9600;
}

/* Buttons */
.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: 16rpx;
}
.link-btn {
  font-size: 28rpx;
  color: #AFAFAF;
  padding: 16rpx;
}
