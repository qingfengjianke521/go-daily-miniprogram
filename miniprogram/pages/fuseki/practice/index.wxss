.page {
  min-height: 100vh;
  background-color: #F7F7F7;
  display: flex;
  flex-direction: column;
}

/* Nav bar */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 8rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 5rpx solid #999;
  border-bottom: 5rpx solid #999;
  transform: rotate(45deg);
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.nav-subtitle {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.nav-spacer {
  width: 80rpx;
}

/* Not found */
.not-found {
  text-align: center;
}

.not-found-text {
  display: block;
  color: #999;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}

/* Main content */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx 48rpx;
}

.description {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.hint-area {
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.hint-error {
  font-size: 28rpx;
  font-weight: 500;
  color: #FF4B4B;
}

.hint-done {
  font-size: 28rpx;
  font-weight: 500;
  color: #58CC02;
}

.hint-color {
  font-size: 24rpx;
  color: #999;
}

/* Board */
.board-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #E5E5E5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background-color: #58CC02;
  transition: width 0.3s;
}

/* Controls */
.controls {
  display: flex;
  gap: 24rpx;
}

.btn-outline {
  flex: 1;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  border: 4rpx solid #E5E5E5;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-outline:active {
  background: #F5F5F5;
}

.btn-primary {
  flex: 1;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background-color: #58CC02;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-small {
  display: inline-flex;
  flex: none;
  padding: 0 48rpx;
}

.btn-disabled {
  opacity: 0.3;
  pointer-events: none;
}
