.page {
  min-height: 100vh;
  background-color: #F7F7F7;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #FFFFFF;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

.inner-content {
  padding: 0 32rpx;
}

.header {
  padding: 32rpx 0 16rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.group {
  margin-top: 32rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.badge {
  padding: 6rpx 24rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.group-count {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
}

.card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}

.card-hover {
  background: #F5F5F5;
}

.card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-icon-text {
  font-size: 32rpx;
  font-weight: bold;
}

.card-body {
  flex: 1;
  min-width: 0;
  margin-left: 28rpx;
}

.card-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #CCC;
  border-right: 4rpx solid #CCC;
  transform: rotate(45deg);
}
