<view class="page">
  <!-- Custom nav bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-inner" style="height: {{navBarHeight}}px;">
      <text class="nav-title">布局练习</text>
    </view>
  </view>

  <!-- Content -->
  <scroll-view scroll-y class="content" style="top: {{statusBarHeight + navBarHeight}}px;">
    <view class="inner-content">
      <view class="header">
        <text class="page-title">布局练习</text>
        <text class="page-subtitle">学习经典布局思路，掌握全局观</text>
      </view>

      <block wx:for="{{groups}}" wx:key="difficulty">
        <view class="group">
          <view class="group-header">
            <view class="badge" style="background-color: {{item.bgColor}}; color: {{item.textColor}};">
              {{item.label}}
            </view>
            <text class="group-count">{{item.count}} 个布局</text>
          </view>

          <view class="card-list">
            <view
              wx:for="{{item.items}}"
              wx:for-item="fuseki"
              wx:key="id"
              class="card"
              hover-class="card-hover"
              bindtap="onTapFuseki"
              data-id="{{fuseki.id}}"
            >
              <view class="card-icon" style="background-color: {{fuseki.bgColor}};">
                <text class="card-icon-text" style="color: {{fuseki.textColor}};">{{fuseki.moveCount}}</text>
              </view>
              <view class="card-body">
                <text class="card-name">{{fuseki.name}}</text>
                <text class="card-desc">{{fuseki.description}}</text>
              </view>
              <view class="card-arrow"></view>
            </view>
          </view>
        </view>
      </block>

      <!-- Bottom padding for tab bar -->
      <view style="height: 180rpx;"></view>
    </view>
  </scroll-view>
</view>
