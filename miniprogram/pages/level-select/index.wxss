.page-level {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF0 0%, #FFFFFF 100%);
}
.content {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 48rpx; gap: 24rpx;
}
.ls-title { font-size: 44rpx; font-weight: 700; color: #4B4B4B; }
.ls-subtitle { font-size: 26rpx; color: #AFAFAF; margin-bottom: 32rpx; }

.level-list {
  width: 100%; display: flex; flex-direction: column; gap: 20rpx;
  margin-bottom: 48rpx;
}
.level-card {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 28rpx;
  background: white;
  border-radius: 16rpx;
  border: 4rpx solid #F0F0F0;
  transition: all 0.2s;
}
.level-card-active {
  border-color: #58CC02;
  background: #F0FBE5;
  box-shadow: 0 4rpx 16rpx rgba(88,204,2,0.15);
}
.level-emoji { font-size: 48rpx; flex-shrink: 0; }
.level-text { display: flex; flex-direction: column; gap: 4rpx; }
.level-name { font-size: 30rpx; font-weight: 700; color: #4B4B4B; }
.level-desc { font-size: 24rpx; color: #AFAFAF; }

.btn-disabled {
  background: #E5E5E5 !important; color: #AFAFAF !important;
  border-bottom: 4rpx solid #CCCCCC !important;
}
