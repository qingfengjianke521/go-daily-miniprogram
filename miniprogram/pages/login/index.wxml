<view class="welcome-page">
  <view style="height: {{statusBarHeight + navBarHeight}}px;"></view>

  <view class="content">
    <!-- 棋盘装饰背景 -->
    <view class="board-deco">
      <view class="board-grid">
        <view wx:for="{{9}}" wx:key="*this" class="grid-h"></view>
        <view wx:for="{{9}}" wx:key="*this" class="grid-v"></view>
      </view>
    </view>

    <!-- 吉祥物：黑白棋子精灵 -->
    <view class="mascot-pair">
      <mascot color="black" mood="wait" size="lg" />
      <mascot color="white" mood="wait" size="lg" />
    </view>

    <!-- 标题 -->
    <text class="welcome-title">黑白天天练</text>
    <text class="welcome-subtitle">每天3道题，棋力日日涨</text>

    <!-- 昵称输入（微信会自动弹出昵称填充） -->
    <view class="nickname-row">
      <input
        type="nickname"
        class="nickname-input"
        placeholder="点击填入微信昵称"
        bindinput="onNicknameInput"
        bindblur="onNicknameInput"
        value="{{nickname}}"
      />
    </view>

    <!-- 3D主按钮 -->
    <button class="start-btn" bindtap="handleStart" disabled="{{loading}}">
      {{loading ? '加载中...' : '开始练习'}}
    </button>

    <text wx:if="{{error}}" class="error-text">{{error}}</text>

    <text class="hint-text">微信授权登录，无需注册</text>

    <!-- 底部装饰：3个小棋子 -->
    <view class="bottom-deco">
      <view class="mini-stone mini-black"></view>
      <view class="mini-stone mini-white"></view>
      <view class="mini-stone mini-black"></view>
      <text class="bottom-deco-text">每天3题</text>
    </view>
  </view>
</view>
