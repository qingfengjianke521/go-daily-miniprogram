.welcome-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FFF0 0%, #FFFFFF 100%);
}
.content {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 64rpx; gap: 24rpx;
}

/* 棋盘装饰 */
.board-deco {
  width: 240rpx; height: 240rpx; position: relative;
  opacity: 0.08; margin-bottom: -120rpx; z-index: 0;
}
.board-grid { width: 100%; height: 100%; position: relative; }
.grid-h {
  position: absolute; left: 0; right: 0; height: 2rpx;
  background: #5C4033;
}
.grid-h:nth-child(1) { top: 0; }
.grid-h:nth-child(2) { top: 12.5%; }
.grid-h:nth-child(3) { top: 25%; }
.grid-h:nth-child(4) { top: 37.5%; }
.grid-h:nth-child(5) { top: 50%; }
.grid-h:nth-child(6) { top: 62.5%; }
.grid-h:nth-child(7) { top: 75%; }
.grid-h:nth-child(8) { top: 87.5%; }
.grid-h:nth-child(9) { top: 100%; }
.grid-v {
  position: absolute; top: 0; bottom: 0; width: 2rpx;
  background: #5C4033;
}
.grid-v:nth-child(10) { left: 0; }
.grid-v:nth-child(11) { left: 12.5%; }
.grid-v:nth-child(12) { left: 25%; }
.grid-v:nth-child(13) { left: 37.5%; }
.grid-v:nth-child(14) { left: 50%; }
.grid-v:nth-child(15) { left: 62.5%; }
.grid-v:nth-child(16) { left: 75%; }
.grid-v:nth-child(17) { left: 87.5%; }
.grid-v:nth-child(18) { left: 100%; }

/* 吉祥物 */
.mascot-pair {
  display: flex; gap: 24rpx; z-index: 1;
  margin-bottom: 24rpx;
}

/* 标题 */
.welcome-title {
  font-size: 56rpx; font-weight: 700; color: #4B4B4B;
}
.welcome-subtitle {
  font-size: 30rpx; color: #58CC02; font-weight: 600;
  margin-bottom: 48rpx;
}

/* 3D按钮 */
.start-btn {
  width: 100% !important;
  height: 96rpx !important; line-height: 96rpx !important;
  background: #58CC02 !important; color: white !important;
  font-size: 36rpx !important; font-weight: 700 !important;
  border-radius: 24rpx !important; border: none !important;
  border-bottom: 8rpx solid #46A302 !important;
  margin: 0 !important; padding: 0 !important;
}
.start-btn:active {
  border-bottom: 0 !important;
  margin-top: 8rpx !important;
}

.error-text { font-size: 26rpx; color: #FF4B4B; }
.hint-text { font-size: 24rpx; color: #CCCCCC; margin-top: 16rpx; }

/* 底部装饰 */
.bottom-deco {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 64rpx; opacity: 0.5;
}
.mini-stone { width: 24rpx; height: 24rpx; border-radius: 50%; }
.mini-black { background: #333; }
.mini-white { background: #eee; border: 2rpx solid #ccc; }
.bottom-deco-text { font-size: 22rpx; color: #AFAFAF; margin-left: 8rpx; }
