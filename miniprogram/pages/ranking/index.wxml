<view class="ranking-page">
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px;">
    <view style="height:44px;" class="flex items-center justify-center">
      <text class="font-bold text-base" style="color:#4B4B4B;">排行榜</text>
    </view>
  </view>

  <!-- 排行标题 -->
  <view class="tab-row">
    <view class="tab tab-on">总排行</view>
  </view>

  <view wx:if="{{loading}}" class="loading-center"><text class="text-999">加载中...</text></view>

  <scroll-view wx:else scroll-y class="rank-scroll">
    <!-- 空状态 -->
    <view wx:if="{{list.length === 0}}" class="empty">
      <text class="empty-icon">🏆</text>
      <text class="empty-title">还没有人上榜</text>
      <text class="empty-sub">成为第一个打卡的棋手吧！</text>
    </view>

    <block wx:else>
      <!-- 领奖台 -->
      <view wx:if="{{topThree.length >= 3}}" class="podium">
        <!-- 第2名 左 -->
        <view class="podium-col">
          <text class="podium-medal">🥈</text>
          <view class="podium-avatar podium-silver">
            <text class="podium-initial">{{topThree[1].initial}}</text>
          </view>
          <text class="podium-name">{{topThree[1].username}}</text>
          <text class="podium-score">{{topThree[1].level_name}}</text>
          <view class="podium-stand stand-2"></view>
        </view>
        <!-- 第1名 中 -->
        <view class="podium-col podium-col-1">
          <text class="podium-medal podium-medal-1">🥇</text>
          <view class="podium-avatar podium-gold">
            <text class="podium-initial">{{topThree[0].initial}}</text>
          </view>
          <text class="podium-name">{{topThree[0].username}}</text>
          <text class="podium-score podium-score-1">{{topThree[0].level_name}}</text>
          <view class="podium-stand stand-1"></view>
        </view>
        <!-- 第3名 右 -->
        <view class="podium-col">
          <text class="podium-medal">🥉</text>
          <view class="podium-avatar podium-bronze">
            <text class="podium-initial">{{topThree[2].initial}}</text>
          </view>
          <text class="podium-name">{{topThree[2].username}}</text>
          <text class="podium-score">{{topThree[2].level_name}}</text>
          <view class="podium-stand stand-3"></view>
        </view>
      </view>

      <!-- 列表 -->
      <view class="rank-list">
        <view wx:for="{{restList}}" wx:key="rank" class="rank-item">
          <text class="rank-num">{{item.rank}}</text>
          <view class="rank-avatar-sm">
            <text>{{item.initial}}</text>
          </view>
          <view class="rank-info">
            <text class="rank-name">{{item.username}}</text>
            <text class="rank-sub">{{item.level_name}}</text>
          </view>
          <text class="rank-score">{{item.rating}}分</text>
        </view>
      </view>
    </block>

    <view style="height:200rpx;"></view>
  </scroll-view>
</view>
