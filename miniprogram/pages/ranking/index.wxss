.ranking-page { min-height: 100vh; background: #F7F7F7; }
.nav-bar { background: white; }

/* Tabs */
.tab-row {
  display: flex; padding: 12rpx 48rpx; gap: 8rpx; background: white;
  border-bottom: 2rpx solid #F0F0F0;
}
.tab {
  flex: 1; text-align: center; padding: 14rpx 0;
  border-radius: 9999rpx; font-size: 24rpx; font-weight: 600;
  color: #AFAFAF; background: #F7F7F7;
}
.tab-on { background: #58CC02; color: white; }

.loading-center { display: flex; align-items: center; justify-content: center; min-height: 40vh; }
.rank-scroll { height: calc(100vh - 160px); }

/* Empty */
.empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 48rpx; gap: 16rpx;
}
.empty-icon { font-size: 96rpx; }
.empty-title { font-size: 32rpx; font-weight: 700; color: #4B4B4B; }
.empty-sub { font-size: 24rpx; color: #AFAFAF; }

/* ===== 领奖台 ===== */
.podium {
  display: flex; justify-content: center; align-items: flex-end;
  padding: 48rpx 32rpx 0; gap: 16rpx;
}
.podium-col {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; width: 180rpx;
}
.podium-col-1 { margin-top: -32rpx; }
.podium-medal { font-size: 36rpx; }
.podium-medal-1 { font-size: 48rpx; }
.podium-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700; color: white;
}
.podium-gold { background: linear-gradient(135deg, #FFD700, #FFA000); border: 4rpx solid #FF8F00; }
.podium-silver { background: linear-gradient(135deg, #E0E0E0, #9E9E9E); border: 4rpx solid #757575; }
.podium-bronze { background: linear-gradient(135deg, #FFCC80, #E65100); border: 4rpx solid #BF360C; }
.podium-initial { font-size: 32rpx; }
.podium-name { font-size: 24rpx; font-weight: 700; color: #4B4B4B; max-width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.podium-score { font-size: 28rpx; font-weight: 700; color: #58CC02; }
.podium-score-1 { font-size: 32rpx; }

/* 台子 */
.podium-stand { width: 100%; border-radius: 16rpx 16rpx 0 0; }
.stand-1 { height: 120rpx; background: linear-gradient(180deg, #FFF8E1, #FFE082); }
.stand-2 { height: 80rpx; background: linear-gradient(180deg, #F5F5F5, #E0E0E0); }
.stand-3 { height: 56rpx; background: linear-gradient(180deg, #FFF3E0, #FFCC80); }

/* ===== 列表 ===== */
.rank-list { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 8rpx; }
.rank-item {
  display: flex; align-items: center; padding: 20rpx 24rpx;
  background: white; border-radius: 16rpx; gap: 16rpx;
}
.rank-num { font-size: 28rpx; font-weight: 700; color: #AFAFAF; min-width: 48rpx; text-align: center; }
.rank-avatar-sm {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #E8F5E9; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700; color: #58CC02;
}
.rank-info { flex: 1; display: flex; flex-direction: column; }
.rank-name { font-size: 24rpx; font-weight: 600; color: #4B4B4B; }
.rank-sub { font-size: 20rpx; color: #AFAFAF; }
.rank-score { font-size: 28rpx; font-weight: 700; color: #58CC02; }
