.ranking-page { min-height: 100vh; background: #F7F7F7; }
.nav-bar { background: white; }

/* Tab bar */
.tab-bar {
  display: flex;
  padding: 16rpx 48rpx;
  gap: 8rpx;
  background: white;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #AFAFAF;
  background: #F7F7F7;
}
.tab-active {
  background: #58CC02;
  color: white;
}

.loading-wrap {
  display: flex; align-items: center; justify-content: center;
  min-height: 40vh;
}

.rank-scroll { height: calc(100vh - 240px); }

/* Podium */
.podium {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
}
.podium-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  min-width: 180rpx;
}
.podium-1 { background: #FFF9E6; border: 4rpx solid #FFD700; }
.podium-2 { background: #F5F5F5; border: 4rpx solid #C0C0C0; }
.podium-3 { background: #FFF5EE; border: 4rpx solid #CD7F32; }
.podium-medal { font-size: 48rpx; }
.podium-name { font-size: 26rpx; font-weight: 700; color: #4B4B4B; }
.podium-change { font-size: 36rpx; font-weight: 700; }
.podium-level { font-size: 22rpx; color: #AFAFAF; }

/* Empty */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx; gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 32rpx; font-weight: 600; color: #4B4B4B; }
.empty-sub { font-size: 26rpx; color: #AFAFAF; }

/* Rank list */
.rank-list { padding: 0 32rpx; display: flex; flex-direction: column; gap: 4rpx; }
.rank-item {
  display: flex; align-items: center;
  padding: 24rpx; background: white;
  border-radius: 16rpx; gap: 20rpx;
}
.rank-num { font-size: 28rpx; font-weight: 700; color: #AFAFAF; min-width: 48rpx; text-align: center; }
.rank-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.rank-name { font-size: 28rpx; font-weight: 600; color: #4B4B4B; }
.rank-sub { font-size: 22rpx; color: #AFAFAF; }
.rank-change { font-size: 32rpx; font-weight: 700; }

/* My rank bar - fixed bottom */
.my-rank-bar {
  position: fixed;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 32rpx; right: 32rpx;
  display: flex; align-items: center;
  padding: 24rpx 32rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.1);
  gap: 20rpx; z-index: 50;
}
.my-rank-num {
  font-size: 28rpx; font-weight: 700; color: #58CC02; min-width: 80rpx;
}
