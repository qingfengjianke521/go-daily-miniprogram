.result-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.result-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  gap: 48rpx;
}

/* Result icon circle */
.result-icon {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* Large checkmark */
.icon-check-lg {
  width: 80rpx;
  height: 80rpx;
  position: relative;
}

.check-stem-lg {
  position: absolute;
  width: 40rpx;
  height: 10rpx;
  background: #FFFFFF;
  border-radius: 5rpx;
  left: 6rpx;
  top: 48rpx;
  transform: rotate(45deg);
}

.check-kick-lg {
  position: absolute;
  width: 56rpx;
  height: 10rpx;
  background: #FFFFFF;
  border-radius: 5rpx;
  left: 24rpx;
  top: 36rpx;
  transform: rotate(-45deg);
}

/* Large cross */
.icon-cross-lg {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.cross-line-lg {
  position: absolute;
  width: 64rpx;
  height: 10rpx;
  background: #FFFFFF;
  border-radius: 5rpx;
  top: 50%;
  left: 0;
  margin-top: -5rpx;
}

.cross-line-lg-1 {
  transform: rotate(45deg);
}

.cross-line-lg-2 {
  transform: rotate(-45deg);
}

/* Message */
.result-message {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
}

/* Rating change */
.result-rating {
  font-size: 96rpx;
  font-weight: 700;
}

/* Replay section */
.replay-section {
  width: 100%;
}

/* Bottom */
.result-bottom {
  padding: 0 48rpx 40rpx;
}

.result-btn-row {
  display: flex;
  gap: 24rpx;
}

.result-btn-row .btn {
  flex: 1;
}
