/* ======================================================
   黑白天天练 - 天梯首页（背景图片+悬浮UI）
   ====================================================== */

/* ===== HUD ===== */
.hud {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.1) 80%, transparent 100%);
  padding-bottom: 30rpx;
}
.hud-row {
  height: 44px; padding: 0 24rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.hud-pill {
  display: flex; align-items: center; gap: 4rpx;
  padding: 6rpx 16rpx; border-radius: 9999rpx; font-size: 24rpx;
}
.hud-fire { background: rgba(255,150,0,0.25); }
.hud-coin { background: rgba(124,58,237,0.25); }
.hud-val { font-weight: 700; color: white; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); }
.hud-level {
  padding: 6rpx 24rpx; border-radius: 20rpx;
  background: linear-gradient(135deg, #FFD54F, #FFB300);
  box-shadow: 0 3rpx 0 #E65100;
}
.hud-level-txt { font-size: 22rpx; font-weight: 700; color: #5D4037; }
.hud-rating { font-size: 22rpx; color: #fff; font-weight: 600; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5); }
.hud-spacer { flex: 1; }

/* 打卡条 */
.hud-checkin {
  height: 44px; padding: 0 24rpx;
  display: flex; align-items: center; gap: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}
.hud-info { padding: 6rpx 24rpx 10rpx; border-top: 1rpx solid #F0F0F0; }
.hud-info-txt { font-size: 22rpx; color: #AFAFAF; }
.ci-label { font-size: 24rpx; font-weight: 600; color: #666; }
.ci-dots { display: flex; gap: 8rpx; }
.ci-dot {
  width: 30rpx; height: 30rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.ci-pending { background: #E5E5E5; }
.ci-current { background: #E5E5E5; border: 2rpx solid #58CC02; }
.ci-correct { background: #58CC02; }
.ci-wrong { background: #FF4B4B; }
.ci-m { color: white; font-size: 18rpx; font-weight: 700; }
.ci-score { font-size: 24rpx; font-weight: 700; }
.ci-go-btn {
  margin-left: auto; padding: 8rpx 28rpx;
  border-radius: 9999rpx; background: #F0F0F0;
}
.ci-green {
  background: #58CC02; box-shadow: 0 4rpx 0 #46A302;
}
.ci-go-txt { font-size: 24rpx; font-weight: 700; color: #4B4B4B; }
.ci-green .ci-go-txt { color: white; }

/* Loading */
.loading-full {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 80vh;
}

/* ===== 世界 ===== */
.world-scroll { position: fixed; left: 0; right: 0; bottom: 0; }

.world-container {
  position: relative; width: 100%;
  background: #0D3B0F; /* 底部草地色兜底 */
}

/* 背景图 */
.world-bg {
  width: 100%; display: block;
  margin: 0; padding: 0;
}

/* ===== 节点覆盖层 ===== */
.nodes-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
}

/* ===== 关卡节点 ===== */
.gn {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex; flex-direction: column;
  align-items: center; gap: 6rpx;
  z-index: 10;
}

/* 发光圈 */
.gn-glow {
  position: absolute;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,179,0,0.35) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: glow-beat 2s ease-in-out infinite;
  z-index: -1;
}
@keyframes glow-beat {
  0%, 100% { transform: translate(-50%,-50%) scale(1); opacity: 0.5; }
  50% { transform: translate(-50%,-50%) scale(1.2); opacity: 1; }
}

/* 圆形按钮 */
.gn-circle {
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  position: relative;
}

/* 已通过：绿色 */
.gn-passed {
  width: 80rpx; height: 80rpx;
  background: linear-gradient(145deg, #66BB6A, #43A047);
  border: 6rpx solid #2E7D32;
  box-shadow: 0 6rpx 0 #1B5E20, 0 4rpx 16rpx rgba(0,0,0,0.25);
}

/* 当前：大号金色 */
.gn-current {
  width: 110rpx; height: 110rpx;
  background: linear-gradient(145deg, #FFD54F, #FFB300, #FF8F00);
  border: 6rpx solid #E65100;
  box-shadow:
    0 8rpx 0 #BF360C,
    0 0 28rpx rgba(255,179,0,0.5),
    inset 0 4rpx 8rpx rgba(255,255,255,0.3);
}

/* 下一个：半透明金色 */
.gn-next {
  width: 80rpx; height: 80rpx;
  background: linear-gradient(145deg, #FFE082, #FFD54F);
  border: 5rpx solid #F9A825;
  box-shadow: 0 5rpx 0 #F57F17;
  opacity: 0.65;
}

/* 锁定：灰色半透明 */
.gn-locked {
  width: 70rpx; height: 70rpx;
  background: rgba(200,200,200,0.6);
  border: 4rpx solid rgba(150,150,150,0.4);
  box-shadow: 0 4rpx 0 rgba(100,100,100,0.3);
}

.gn-check { color: white; font-size: 38rpx; font-weight: 700; }
.gn-lock { font-size: 28rpx; opacity: 0.6; }
.gn-num {
  color: white; font-size: 36rpx; font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* 脉冲 */
.gn-pulse { animation: gn-pulse 2s ease-in-out infinite; }
@keyframes gn-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

/* 等级名 */
.gn-name {
  font-size: 22rpx; font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.7);
  background: rgba(0,0,0,0.25);
  padding: 2rpx 12rpx; border-radius: 8rpx;
}

/* 精灵位置 */
.gn-mascot {
  position: absolute;
  right: -80rpx; top: -20rpx;
}

/* ===== 目标选择弹窗 ===== */
.goal-mask {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
}
.goal-dialog {
  width: 80%; background: white; border-radius: 32rpx;
  padding: 48rpx 36rpx; display: flex; flex-direction: column; align-items: center; gap: 24rpx;
}
.goal-title { font-size: 36rpx; font-weight: 700; color: #4B4B4B; }
.goal-sub { font-size: 24rpx; color: #AFAFAF; }
.goal-options { width: 100%; display: flex; flex-direction: column; gap: 16rpx; }
.goal-opt {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx; border-radius: 16rpx; border: 3rpx solid #E5E5E5;
}
.goal-opt-on { border-color: #58CC02; background: #F0FFF0; }
.goal-num { font-size: 36rpx; font-weight: 800; color: #58CC02; min-width: 64rpx; text-align: center; }
.goal-label { font-size: 28rpx; font-weight: 600; color: #4B4B4B; }
.goal-desc { font-size: 22rpx; color: #AFAFAF; margin-left: auto; }
.hud-goal { background: rgba(88,204,2,0.25); }
