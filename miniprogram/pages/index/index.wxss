/* ===== 顶部固定栏 ===== */
.top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.status-row {
  height: 44px; padding: 0 28rpx;
  display: flex; align-items: center; gap: 16rpx;
}
.st-pill {
  display: flex; align-items: center; gap: 4rpx;
  padding: 6rpx 16rpx; border-radius: 9999rpx;
  font-size: 24rpx;
}
.fire-pill { background: #FFF3E0; }
.fire-val { font-weight: 700; color: #FF9600; }
.coin-pill { background: #F3E8FF; }
.coin-val { font-weight: 700; color: #7C3AED; }
.st-badge {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  border: 4rpx solid #ccc; background: white;
  display: flex; align-items: center; justify-content: center;
}
.st-rating { font-size: 24rpx; color: #999; font-weight: 600; }
.st-spacer { flex: 1; }

/* 打卡条 */
.checkin-bar {
  height: 48px; padding: 0 28rpx;
  display: flex; align-items: center; gap: 12rpx;
  border-top: 2rpx solid #F0F0F0;
}
.ci-emoji { font-size: 28rpx; }
.ci-txt { font-size: 24rpx; font-weight: 600; color: #4B4B4B; }
.ci-done-txt { color: #58CC02; }
.ci-dots { display: flex; gap: 8rpx; }
.ci-dot {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.ci-dot-pending { background: #E5E5E5; }
.ci-dot-current { background: #E5E5E5; border: 3rpx solid #58CC02; }
.ci-dot-correct { background: #58CC02; }
.ci-dot-wrong { background: #FF4B4B; }
.ci-mark { color: white; font-size: 18rpx; font-weight: 700; }
.ci-change { font-size: 24rpx; font-weight: 700; }
.ci-btn {
  margin-left: auto;
  padding: 8rpx 32rpx;
  border-radius: 9999rpx;
  background: #F0F0F0;
}
.ci-btn-green { background: #58CC02; box-shadow: 0 4rpx 0 #46A302; }
.ci-btn-green .ci-btn-txt { color: white; }
.ci-btn-txt { font-size: 24rpx; font-weight: 700; color: #4B4B4B; }

.loading-center {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh;
}

/* ===== 滚动区域 ===== */
.path-scroll { position: fixed; left: 0; right: 0; bottom: 0; }

/* ===== 世界背景 ===== */
.path-world {
  position: relative;
  min-height: 4000rpx;
  overflow: hidden;
}
.zone {
  position: absolute; left: 0; right: 0;
}
.zone-gold {
  top: 0; height: 25%;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFDE7 50%, #EDE7F6 100%);
}
.zone-purple {
  top: 25%; height: 20%;
  background: linear-gradient(180deg, #EDE7F6 0%, #E8EAF6 50%, #E3F2FD 100%);
}
.zone-sky {
  top: 45%; height: 25%;
  background: linear-gradient(180deg, #E3F2FD 0%, #E8F5E9 100%);
}
.zone-grass {
  top: 70%; bottom: 0;
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 100%);
}

/* ===== 装饰：星星 ===== */
.star {
  font-size: 28rpx; color: #FFD700;
  animation: twinkle 2.5s ease-in-out infinite;
}
.star-1 { top: 3%; right: 15%; }
.star-2 { top: 8%; left: 10%; font-size: 22rpx; animation-delay: 0.8s; }
.star-3 { top: 14%; right: 25%; font-size: 18rpx; animation-delay: 1.5s; }
.star-4 { top: 20%; left: 20%; font-size: 32rpx; animation-delay: 0.4s; }
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.3) rotate(15deg); }
}
.deco { position: absolute; z-index: 2; }

/* ===== 装饰：云朵 ===== */
.deco-cloud {
  position: absolute; z-index: 2;
  animation: drift 28s ease-in-out infinite;
}
.cloud-a { top: 50%; left: 5%; }
.cloud-b { top: 58%; right: 8%; animation-delay: -14s; }
.cloud-c { top: 42%; left: 60%; animation-delay: -8s; }
.c-puff {
  width: 56rpx; height: 30rpx;
  background: rgba(255,255,255,0.65);
  border-radius: 30rpx; position: absolute;
}
.c-puff.p2 { width: 44rpx; height: 26rpx; top: -12rpx; left: 14rpx; }
.c-puff.p3 { width: 36rpx; height: 22rpx; top: -6rpx; left: 32rpx; }
.c-puff.sm { width: 36rpx; height: 20rpx; }
.c-puff.sm.p2 { width: 28rpx; height: 16rpx; top: -10rpx; left: 10rpx; }
@keyframes drift {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(24rpx); }
}

/* ===== 装饰：草和花 ===== */
.deco-grass { position: absolute; z-index: 2; display: flex; gap: 4rpx; }
.g1 { bottom: 8%; left: 6%; }
.g2 { bottom: 12%; right: 8%; }
.g3 { bottom: 5%; left: 45%; }
.blade {
  width: 4rpx; height: 28rpx;
  background: #66BB6A; border-radius: 2rpx 2rpx 0 0;
  transform: rotate(-10deg); transform-origin: bottom;
}
.blade.b2 { height: 36rpx; transform: rotate(0); background: #4CAF50; }
.blade.b3 { height: 22rpx; transform: rotate(12deg); }

.deco-flower { position: absolute; z-index: 2; width: 24rpx; height: 24rpx; }
.f1 { bottom: 10%; left: 18%; }
.f2 { bottom: 7%; right: 20%; }
.petal {
  position: absolute; width: 10rpx; height: 10rpx;
  background: #FF8A80; border-radius: 50%;
  top: 0; left: 7rpx;
}
.petal.r2 { top: 7rpx; left: 14rpx; background: #FF80AB; }
.petal.r3 { top: 14rpx; left: 7rpx; background: #FF8A80; }
.petal.r4 { top: 7rpx; left: 0; background: #FF80AB; }
.stamen {
  position: absolute; width: 8rpx; height: 8rpx;
  background: #FFD54F; border-radius: 50%;
  top: 8rpx; left: 8rpx;
}

/* ===== 装饰：小棋子 ===== */
.mini-stone {
  width: 18rpx; height: 18rpx; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #555, #111);
  opacity: 0.15;
}
.mini-stone.white {
  background: radial-gradient(circle at 35% 30%, #fff, #ccc);
  border: 1rpx solid #ddd;
}
.ms1 { top: 30%; right: 8%; }
.ms2 { top: 65%; left: 5%; }
.ms3 { bottom: 18%; right: 12%; }

/* ===== 段位分界线 ===== */
.dan-divider {
  position: absolute; left: 0; right: 0;
  display: flex; align-items: center; gap: 16rpx;
  padding: 0 32rpx; z-index: 5;
}
.dan-line { flex: 1; height: 4rpx; background: linear-gradient(90deg, transparent, #FFD700, transparent); border-radius: 2rpx; }
.dan-label {
  font-size: 22rpx; font-weight: 700; color: #FFB300;
  background: #FFF8E1; padding: 8rpx 24rpx; border-radius: 9999rpx;
  white-space: nowrap;
}

/* 起点旗帜 */
.start-flag {
  position: absolute; bottom: 4%; right: 15%;
  font-size: 40rpx; z-index: 3;
}

/* ===== 节点容器 ===== */
.nodes-container {
  position: relative; z-index: 10;
  padding: 48rpx 32rpx 0;
  display: flex;
  flex-direction: column-reverse;
}

/* ===== 节点行 ===== */
.node-row {
  display: flex; align-items: center;
  padding: 16rpx 0;
  min-height: 140rpx;
  position: relative;
}
.node-left { justify-content: flex-start; padding-left: 32rpx; }
.node-right { justify-content: flex-end; padding-right: 32rpx; flex-direction: row-reverse; }

/* ===== 连接线（粗圆角） ===== */
.path-line {
  position: absolute; z-index: 5;
  width: 10rpx; height: 100rpx;
  border-radius: 5rpx;
  top: -50rpx;
}
.path-line-left { left: 84rpx; }
.path-line-right { right: 84rpx; }
.line-done {
  background: linear-gradient(180deg, #58CC02, #6BDB18);
  box-shadow: 0 0 12rpx rgba(88,204,2,0.3);
}
.line-locked { background: #E0E0E0; width: 8rpx; }

/* ===== 节点圆圈 ===== */
.node {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  position: relative; flex-shrink: 0;
  transition: all 0.3s;
}
.nd-passed {
  background: linear-gradient(135deg, #6BDB18, #58CC02);
  box-shadow: 0 8rpx 0 #46A302, 0 4rpx 16rpx rgba(88,204,2,0.3);
}
.nd-current {
  width: 110rpx; height: 110rpx;
  background: linear-gradient(135deg, #7AE635, #58CC02);
  box-shadow: 0 10rpx 0 #46A302, 0 0 32rpx rgba(88,204,2,0.4);
  border: 4rpx solid rgba(255,255,255,0.4);
}
.nd-next {
  background: rgba(88,204,2,0.12);
  border: 4rpx dashed #58CC02;
}
.nd-locked {
  background: linear-gradient(135deg, #F5F5F5, #E0E0E0);
  box-shadow: 0 6rpx 0 #CCCCCC;
}

.nd-icon { color: white; font-size: 40rpx; font-weight: 700; }
.nd-cur-label { color: white; font-size: 36rpx; font-weight: 800; }
.nd-next-label { color: #58CC02; font-size: 28rpx; font-weight: 700; opacity: 0.6; }
.nd-lock { font-size: 28rpx; opacity: 0.5; }

/* 3D底座 */
.nd-base {
  position: absolute; bottom: -10rpx; left: 15%; width: 70%;
  height: 12rpx; border-radius: 50%;
}
.nd-base-passed { background: rgba(70,163,2,0.4); }
.nd-base-current { background: rgba(70,163,2,0.5); }
.nd-base-locked { background: rgba(0,0,0,0.08); }

/* 呼吸动画 */
.nd-breathe {
  animation: breathe 2s ease-in-out infinite;
}
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

/* 粒子光环 */
.node-glow {
  position: absolute;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  border: 3rpx dashed rgba(88,204,2,0.4);
  animation: glow-spin 8s linear infinite, breathe 2s ease-in-out infinite;
  z-index: -1;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
}
@keyframes glow-spin {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

/* 锁定雾气 */
.node-fog {
  position: absolute;
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.5) 30%, transparent 70%);
  z-index: -1;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
}

/* 当前节点旁的精灵 */
.node-mascot {
  position: relative;
  margin: 0 12rpx;
}
.bounce-arrow {
  text-align: center;
  font-size: 20rpx; color: #58CC02; font-weight: 700;
  animation: bounce-ud 1s ease infinite;
}
@keyframes bounce-ud {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(8rpx); }
}

/* ===== 标签 ===== */
.nd-label {
  display: flex; flex-direction: column;
  gap: 4rpx; margin: 0 16rpx;
}
.nd-name { font-size: 26rpx; font-weight: 700; color: #4B4B4B; }
.nd-sub { font-size: 20rpx; color: #AFAFAF; }
.nd-sub.green { color: #58CC02; font-weight: 600; }
.nd-sub.gray { color: #BDBDBD; }

/* 奖励气泡 */
.reward-bubble {
  position: absolute; right: 20rpx;
  padding: 6rpx 14rpx;
  background: #FFF8E1; border-radius: 9999rpx;
  font-size: 18rpx; font-weight: 700; color: #FFB300;
  box-shadow: 0 2rpx 8rpx rgba(255,179,0,0.2);
}
.node-right .reward-bubble { right: auto; left: 20rpx; }
