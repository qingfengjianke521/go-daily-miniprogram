/* ======================================================
   黑白天天练 - 天梯首页（插画风格）
   参考：多邻国路径 + Cookie Run 地图 + 旅行青蛙
   ====================================================== */

/* ===== HUD 顶部状态栏 ===== */
.hud {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(20, 40, 80, 0.75);
  backdrop-filter: blur(12px);
}
.hud-row {
  height: 44px; padding: 0 24rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.hud-pill {
  display: flex; align-items: center; gap: 4rpx;
  padding: 6rpx 16rpx; border-radius: 9999rpx;
  font-size: 22rpx;
}
.hud-fire { background: rgba(255,150,0,0.2); }
.hud-coin { background: rgba(124,58,237,0.2); }
.hud-val { font-weight: 700; color: white; }
.hud-level {
  padding: 6rpx 24rpx; border-radius: 20rpx;
  background: linear-gradient(135deg, #FFD54F, #FFB300);
  box-shadow: 0 4rpx 0 #E65100, inset 0 2rpx 0 rgba(255,255,255,0.3);
}
.hud-level-txt { font-size: 22rpx; font-weight: 700; color: #5D4037; }
.hud-spacer { flex: 1; }

/* 打卡条 */
.hud-checkin {
  height: 44px; padding: 0 24rpx;
  display: flex; align-items: center; gap: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}
.hud-ci-txt { font-size: 22rpx; font-weight: 600; color: rgba(255,255,255,0.8); }
.hud-ci-dots { display: flex; gap: 8rpx; }
.hud-dot {
  width: 28rpx; height: 28rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.hud-dot-pending { background: rgba(255,255,255,0.2); }
.hud-dot-current { background: rgba(255,255,255,0.2); border: 2rpx solid #58CC02; }
.hud-dot-correct { background: #58CC02; }
.hud-dot-wrong { background: #FF4B4B; }
.hud-dot-mark { color: white; font-size: 16rpx; font-weight: 700; }
.hud-ci-change { font-size: 22rpx; font-weight: 700; color: white; }
.hud-ci-btn {
  margin-left: auto; padding: 8rpx 28rpx;
  border-radius: 9999rpx; background: rgba(255,255,255,0.15);
}
.hud-ci-btn-go {
  background: #58CC02; box-shadow: 0 4rpx 0 #46A302;
}

.world-loading {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 80vh;
  background: #1B5E20;
}

/* ===== 世界滚动区 ===== */
.world-scroll { position: fixed; left: 0; right: 0; bottom: 0; }

.world {
  position: relative;
  overflow: hidden;
}

/* ===== 背景层 ===== */
.bg-layer { position: absolute; inset: 0; z-index: 0; }

.bg-forest {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 35%;
  background: linear-gradient(180deg,
    #2E7D32 0%,
    #1B5E20 30%,
    #0D3B0F 100%
  );
}
.bg-meadow {
  position: absolute; bottom: 35%; left: 0; right: 0;
  height: 35%;
  background: linear-gradient(180deg,
    #64B5F6 0%,
    #81C784 30%,
    #4CAF50 60%,
    #2E7D32 100%
  );
}
.bg-sky {
  position: absolute; top: 0; left: 0; right: 0;
  height: 30%;
  background: linear-gradient(180deg,
    #1A237E 0%,
    #283593 30%,
    #3949AB 60%,
    #64B5F6 100%
  );
}

/* ===== 月亮和星星 ===== */
.d-moon {
  position: absolute; top: 8%; right: 20%;
  font-size: 64rpx; z-index: 2;
  filter: drop-shadow(0 0 20rpx rgba(255,255,200,0.4));
}
.d-star {
  position: absolute; z-index: 2;
  color: #FFF9C4;
  animation: twinkle 3s ease-in-out infinite;
}
.s1 { top: 3%; left: 15%; font-size: 20rpx; }
.s2 { top: 6%; right: 10%; font-size: 16rpx; animation-delay: 0.7s; }
.s3 { top: 12%; left: 35%; font-size: 12rpx; animation-delay: 1.4s; }
.s4 { top: 5%; left: 60%; font-size: 14rpx; animation-delay: 0.3s; }
.s5 { top: 15%; right: 30%; font-size: 10rpx; animation-delay: 2s; }
.s6 { top: 9%; left: 45%; font-size: 18rpx; animation-delay: 1.1s; }
@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* ===== 云朵 ===== */
.d-cloud { position: absolute; z-index: 3; animation: drift 30s ease-in-out infinite; }
.cl1 { top: 25%; left: 5%; }
.cl2 { top: 32%; right: 3%; animation-delay: -15s; }
.cl3 { top: 22%; left: 55%; animation-delay: -8s; }
.cl-p {
  width: 80rpx; height: 40rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 40rpx; position: absolute;
}
.cl-p.p2 { width: 64rpx; height: 36rpx; top: -16rpx; left: 16rpx; }
.cl-p.p3 { width: 52rpx; height: 28rpx; top: -8rpx; left: 44rpx; }
.cl-p.sm { width: 48rpx; height: 24rpx; }
.cl-p.sm.p2 { width: 36rpx; height: 20rpx; top: -12rpx; left: 12rpx; }
@keyframes drift {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(30rpx); }
}

/* ===== 树木剪影 ===== */
.d-tree {
  position: absolute; z-index: 4;
  width: 80rpx; height: 120rpx;
  background: #1B5E20;
  border-radius: 50% 50% 8rpx 8rpx;
  opacity: 0.5;
}
.d-tree::after {
  content: ''; position: absolute;
  bottom: 0; left: 35%; width: 30%; height: 30%;
  background: #33691E; border-radius: 4rpx;
}
.t1 { bottom: 40%; left: 3%; }
.t2 { bottom: 45%; right: 5%; width: 60rpx; height: 100rpx; }
.t3.small { bottom: 38%; left: 25%; width: 40rpx; height: 70rpx; opacity: 0.3; }

/* ===== 蘑菇 ===== */
.d-mush { position: absolute; z-index: 5; }
.m1 { bottom: 18%; right: 12%; }
.m2 { bottom: 22%; left: 8%; }
.m3 { bottom: 12%; left: 55%; }

.mush-cap {
  width: 48rpx; height: 28rpx;
  background: linear-gradient(135deg, #E53935, #C62828);
  border-radius: 48rpx 48rpx 8rpx 8rpx;
  position: relative;
}
.mush-stem {
  width: 20rpx; height: 20rpx;
  background: #FFECB3;
  border-radius: 0 0 8rpx 8rpx;
  margin: 0 auto;
}
.mush-dot {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.8);
}
.mush-dot.md1 { width: 10rpx; height: 10rpx; top: 6rpx; left: 8rpx; }
.mush-dot.md2 { width: 8rpx; height: 8rpx; top: 10rpx; right: 10rpx; }

.small-cap { width: 32rpx; height: 20rpx; }
.small-stem { width: 14rpx; height: 14rpx; }
.small-dot { width: 6rpx; height: 6rpx; }

/* ===== 小白花 ===== */
.d-flower {
  position: absolute; z-index: 5;
  font-size: 20rpx; color: rgba(255,255,255,0.7);
}
.fl1 { bottom: 15%; left: 20%; }
.fl2 { bottom: 20%; right: 25%; }
.fl3 { bottom: 25%; left: 40%; font-size: 16rpx; }
.fl4 { bottom: 10%; left: 70%; }
.fl5 { bottom: 30%; right: 15%; font-size: 14rpx; }
.fl6 { bottom: 8%; left: 35%; font-size: 18rpx; }

/* ===== 段位分界线 ===== */
.dan-divider {
  position: absolute; left: 0; right: 0;
  display: flex; align-items: center; gap: 12rpx;
  padding: 0 24rpx; z-index: 8;
}
.dan-glow-line {
  flex: 1; height: 4rpx;
  background: linear-gradient(90deg, transparent, #FFD700, transparent);
  box-shadow: 0 0 12rpx rgba(255,215,0,0.5);
}
.dan-badge {
  font-size: 20rpx; font-weight: 700; color: #FFB300;
  background: rgba(255,248,225,0.9); padding: 8rpx 20rpx;
  border-radius: 9999rpx; white-space: nowrap;
  border: 2rpx solid #FFD54F;
  box-shadow: 0 0 16rpx rgba(255,215,0,0.3);
}

/* ===== 米白色S形路径 ===== */
.road-container {
  position: absolute; inset: 0; z-index: 6;
}
.road-segment {
  position: absolute;
  background: linear-gradient(180deg,
    #FFF8E1 0%,
    #F5EDCB 50%,
    #E8DDB5 100%
  );
  border: 3rpx solid rgba(139,119,80,0.2);
  box-shadow:
    inset 0 4rpx 8rpx rgba(255,255,255,0.3),
    0 4rpx 12rpx rgba(0,0,0,0.15);
}

/* ===== 关卡节点 ===== */
.nodes-layer {
  position: absolute; inset: 0; z-index: 10;
}
.gnode {
  position: absolute;
  display: flex; flex-direction: column;
  align-items: center; gap: 6rpx;
  transform: translateX(-50%);
}

/* 发光圈 */
.gnode-glow {
  position: absolute;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,215,0,0.3) 0%, transparent 70%);
  top: -30rpx; left: 50%;
  transform: translateX(-50%);
  animation: glow-pulse 2s ease-in-out infinite;
}
@keyframes glow-pulse {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.6; }
  50% { transform: translateX(-50%) scale(1.15); opacity: 1; }
}

/* 节点圆形 */
.gnode-circle {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}

/* 金色（当前+下一个） */
.gnode-current {
  width: 108rpx; height: 108rpx;
  background: linear-gradient(135deg, #FFD54F 0%, #FFB300 50%, #FF8F00 100%);
  border: 6rpx solid #E65100;
  box-shadow:
    0 8rpx 0 #BF360C,
    0 0 24rpx rgba(255,179,0,0.5),
    inset 0 4rpx 8rpx rgba(255,255,255,0.4);
}
.gnode-next {
  background: linear-gradient(135deg, #FFE082 0%, #FFD54F 100%);
  border: 5rpx solid #F9A825;
  box-shadow: 0 6rpx 0 #F57F17;
  opacity: 0.7;
}

/* 绿色（已通过） */
.gnode-passed {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  border: 5rpx solid #2E7D32;
  box-shadow: 0 6rpx 0 #1B5E20;
}

/* 灰色（锁定） */
.gnode-locked {
  background: linear-gradient(135deg, #BDBDBD 0%, #9E9E9E 100%);
  border: 4rpx solid #757575;
  box-shadow: 0 5rpx 0 #616161;
  opacity: 0.5;
}

.gnode-icon { color: white; font-size: 36rpx; font-weight: 700; }
.gnode-lock-icon { font-size: 28rpx; opacity: 0.7; }
.gnode-num {
  color: white; font-size: 34rpx; font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* 脉冲动画 */
.gnode-pulse { animation: node-pulse 2s ease-in-out infinite; }
@keyframes node-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

/* 节点名 */
.gnode-name {
  font-size: 20rpx; font-weight: 700;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.5);
}

/* 当前节点旁精灵 */
.gnode-mascot {
  position: absolute;
  right: -80rpx; top: -10rpx;
}
