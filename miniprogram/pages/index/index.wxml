<!-- ===== 顶部HUD（半透明浮层） ===== -->
<view class="hud" style="padding-top:{{statusBarHeight}}px;">
  <view class="hud-row">
    <view class="hud-pill hud-fire" wx:if="{{stats.streak_days > 0}}">
      <text>🔥</text><text class="hud-val">{{stats.streak_days}}</text>
    </view>
    <view class="hud-level">
      <text class="hud-level-txt">{{stats.level_name || '--'}}</text>
    </view>
    <text class="hud-rating">棋力 {{stats.rating || '--'}}</text>
    <view class="hud-spacer"></view>
    <view class="hud-pill hud-coin">
      <text>💎</text><text class="hud-val">{{stats.coins || 0}}</text>
    </view>
  </view>
  <!-- 打卡条 -->
  <view class="hud-checkin">
    <block wx:if="{{checkedIn}}">
      <text class="ci-label" style="color:#58CC02;">🎉 已打卡</text>
      <view class="ci-dots">
        <view wx:for="{{circles}}" wx:key="number" class="ci-dot ci-{{item.status}}">
          <text wx:if="{{item.status==='correct'}}" class="ci-m">✓</text>
          <text wx:elif="{{item.status==='wrong'}}" class="ci-m">✕</text>
        </view>
      </view>
      <text class="ci-score" style="color:{{totalChange>=0?'#58CC02':'#FF4B4B'}}">{{totalChange>=0?'+':''}}{{totalChange}}</text>
      <view class="ci-go-btn" bindtap="handleStart"><text class="ci-go-txt">继续</text></view>
    </block>
    <block wx:else>
      <text class="ci-label">今日目标</text>
      <view class="ci-dots">
        <view wx:for="{{circles}}" wx:key="number" class="ci-dot ci-{{item.status}}">
          <text wx:if="{{item.status==='correct'}}" class="ci-m">✓</text>
          <text wx:elif="{{item.status==='wrong'}}" class="ci-m">✕</text>
        </view>
      </view>
      <view class="ci-go-btn ci-green" bindtap="handleStart">
        <text class="ci-go-txt">{{completedCount > 0 ? '继续' : '开始'}}</text>
      </view>
    </block>
  </view>
</view>

<!-- 加载 -->
<view wx:if="{{loading}}" class="loading-full" style="padding-top:{{topHeight}}px;">
  <mascot color="black" mood="wait" size="lg" bubble="加载中..." />
</view>

<!-- ===== 主世界 ===== -->
<scroll-view
  wx:else
  scroll-y
  class="world-scroll"
  style="top:{{topHeight}}px;"
  scroll-into-view="{{scrollTarget}}"
  enhanced="{{true}}"
  show-scrollbar="{{false}}"
>
  <!-- 背景图片层 -->
  <view class="world-container">
    <image class="world-bg" src="/images/world-bg.jpg" mode="widthFix" />

    <!-- ===== 悬浮UI：关卡节点 ===== -->
    <view class="nodes-overlay">
      <block wx:for="{{nodes}}" wx:key="id">
        <view
          id="node-{{item.id}}"
          class="gn"
          style="left:{{item.pctX}}%;top:{{item.pctY}}%;"
          bindtap="onTapNode"
          data-idx="{{index}}"
        >
          <!-- 发光（当前） -->
          <view wx:if="{{item.status === 'current'}}" class="gn-glow"></view>

          <!-- 圆形节点 -->
          <view class="gn-circle gn-{{item.status}} {{item.status === 'current' ? 'gn-pulse' : ''}}">
            <text wx:if="{{item.status === 'passed'}}" class="gn-check">✓</text>
            <text wx:elif="{{item.status === 'locked'}}" class="gn-lock">🔒</text>
            <text wx:else class="gn-num">{{item.label}}</text>
          </view>

          <!-- 等级名 -->
          <text class="gn-name">{{item.name}}</text>

          <!-- 当前节点：小黑精灵 -->
          <view wx:if="{{item.status === 'current'}}" class="gn-mascot">
            <mascot color="black" mood="wait" size="sm" bubble="冲！" />
          </view>
        </view>
      </block>
    </view>

    <!-- 底部留白 -->
    <view style="height:200rpx;"></view>
  </view>
</scroll-view>
